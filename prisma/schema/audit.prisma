/// Immutable audit trail — append-only, never UPDATE or DELETE.
model AuditLog {
  id         String          @id @default(cuid())
  tenantId   String?         // null for super admin cross-tenant actions
  actorId    String?         // employeeId, null for system/super-admin actions
  action     String          // e.g. "PUNCH_RECORDED", "TIMESHEET_SUBMITTED"
  entityType AuditEntityType
  entityId   String
  changes    Json?           // { before: {...}, after: {...} }
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())

  tenant Tenant?  @relation(fields: [tenantId], references: [id])
  actor  Employee? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
